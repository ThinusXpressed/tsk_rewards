generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  importBatches  ImportBatch[]
  monthlyReports MonthlyReport[]

  @@map("admins")
}

model Participant {
  id          String   @id @default(uuid())
  csvName     String   @unique @map("csv_name")
  displayName String   @map("display_name")
  boltCardId  String?  @map("bolt_card_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  attendanceRecords    AttendanceRecord[]
  monthlyReportEntries MonthlyReportEntry[]

  @@map("participants")
}

model AttendanceRecord {
  id            String   @id @default(uuid())
  participantId String   @map("participant_id")
  date          DateTime @db.Date
  status        Int      @db.SmallInt // 1 = present, -1 = absent
  importBatchId String   @map("import_batch_id")
  createdAt     DateTime @default(now()) @map("created_at")

  participant Participant @relation(fields: [participantId], references: [id])
  importBatch ImportBatch @relation(fields: [importBatchId], references: [id])

  @@unique([participantId, date])
  @@map("attendance_records")
}

model ImportBatch {
  id             String   @id @default(uuid())
  filename       String
  month          String // e.g. "2026-02"
  importedBy     String   @map("imported_by")
  recordCount    Int      @map("record_count")
  matchedCount   Int      @map("matched_count")
  unmatchedNames String[] @map("unmatched_names")
  createdAt      DateTime @default(now()) @map("created_at")

  admin             Admin              @relation(fields: [importedBy], references: [id])
  attendanceRecords AttendanceRecord[]

  @@map("import_batches")
}

model MonthlyReport {
  id          String   @id @default(uuid())
  month       String // e.g. "2026-02"
  generatedAt DateTime @default(now()) @map("generated_at")
  generatedBy String   @map("generated_by")

  admin   Admin                @relation(fields: [generatedBy], references: [id])
  entries MonthlyReportEntry[]

  @@map("monthly_reports")
}

model MonthlyReportEntry {
  id             String   @id @default(uuid())
  reportId       String   @map("report_id")
  participantId  String   @map("participant_id")
  totalSessions  Int      @map("total_sessions")
  attended       Int
  percentage     Decimal  @db.Decimal(5, 2)
  rewardSats     Int      @map("reward_sats")
  payoutStatus   String   @default("pending") @map("payout_status")
  btcpayPayoutId String?  @map("btcpay_payout_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  report      MonthlyReport @relation(fields: [reportId], references: [id])
  participant Participant   @relation(fields: [participantId], references: [id])

  @@map("monthly_report_entries")
}
